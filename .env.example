# Kredensial & konfigurasi lab. Untuk belajar lokal saja — JANGAN dipakai di produksi.
# File ini sengaja di-commit agar lab gampang dijalankan; di proyek nyata, .env harus di-gitignore.

# --- NiFi (login UI) --- password WAJIB minimal 12 karakter ---
NIFI_USER=admin
NIFI_PASSWORD=xxxxxxxxxxxx

# --- PostgreSQL ---
POSTGRES_USER=mlops
POSTGRES_PASSWORD=xxxxxxxxxxxx
